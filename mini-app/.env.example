# Mini App env (copy to .env.local for local Vite — never commit secrets)
#
# Vite inlines these at BUILD time only. Setting them in Vercel without a
# Redeploy does nothing. Names must match exactly (VITE_ prefix required).

# mock (default when unset) | live
# Production (Vercel → Environment Variables → Production):
#   VITE_ALMAS_API_MODE=live
#   VITE_ALMAS_API_URL=https://web-production-6d53b.up.railway.app
# Then: Deployments → … → Redeploy (or push a new commit). Build must see both.
VITE_ALMAS_API_MODE=mock

# Required when VITE_ALMAS_API_MODE=live (public HTTPS API origin, no trailing slash)
# Local live: VITE_ALMAS_API_URL=http://127.0.0.1:8787
# Production: VITE_ALMAS_API_URL=https://web-production-6d53b.up.railway.app
# VITE_ALMAS_API_URL=
